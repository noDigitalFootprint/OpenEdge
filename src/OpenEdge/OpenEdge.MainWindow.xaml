<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="OpenEdge.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:local="clr-namespace:OpenEdge" x:Name="openEdgePage" WindowTitle="OpenEdge">
  <Grid Name="myGrid" ZIndex="100">
    <Grid.ColumnDefinitions>
      <ColumnDefinition />
      <ColumnDefinition />
      <ColumnDefinition />
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition />
      <RowDefinition />
      <RowDefinition />
      <RowDefinition />
      <RowDefinition />
      <RowDefinition />
      <RowDefinition />
      <RowDefinition />
      <RowDefinition />
      <RowDefinition />
      <RowDefinition />
      <RowDefinition />
    </Grid.RowDefinitions>
    <Grid Name="secGrid" ColumnSpan="3" RowSpan="12" />
    <Grid Name="myGrid2" Column="0" RowSpan="12" Row="0" ColumnSpan="3" ZIndex="1000">
      <Grid.ColumnDefinitions>
        <ColumnDefinition />
        <ColumnDefinition />
        <ColumnDefinition />
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <RowDefinition />
        <RowDefinition />
        <RowDefinition />
        <RowDefinition />
        <RowDefinition />
        <RowDefinition />
        <RowDefinition />
        <RowDefinition />
        <RowDefinition />
        <RowDefinition />
        <RowDefinition />
        <RowDefinition />
      </Grid.RowDefinitions>
      <Image Name="spiral" Grid.Column="0" Grid.RowSpan="12" Grid.Row="0" Grid.ColumnSpan="3" Source="/spiralnew.png" Opacity="1" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False" Visibility="Hidden" Stretch="Uniform">
        <UIElement.Effect>
          <BlurEffect Radius="0" x:Name="spiralBlurEffect" />
        </UIElement.Effect>
      </Image>
      <Image Name="hypnoOverlay" Source="/hypnooverlay.png" Grid.Column="0" Grid.RowSpan="12" Grid.Row="0" Grid.ColumnSpan="3" Visibility="Hidden" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False" RenderTransformOrigin="0.5,0.5" Stretch="UniformToFill" />
      <Rectangle Name="strobeRect" Grid.ColumnSpan="3" Grid.RowSpan="12" Fill="#FFFFFFFF" Visibility="Collapsed" />
      <TextBlock Name="textTopLeft" HorizontalAlignment="Right" VerticalAlignment="Bottom" Visibility="Hidden" Grid.Column="0" Grid.Row="2" FontFamily="Times New Roman" FontSize="72" Margin="-30" />
      <TextBlock Name="textTopRight" HorizontalAlignment="Left" VerticalAlignment="Bottom" Visibility="Hidden" Grid.Column="2" Grid.Row="2" FontFamily="Times New Roman" FontSize="72" Margin="-30" />
      <TextBlock Name="textBotLeft" HorizontalAlignment="Right" VerticalAlignment="Top" Visibility="Hidden" Grid.Column="0" Grid.Row="9" FontFamily="Times New Roman" FontSize="72" Margin="-30" />
      <TextBlock Name="textBotRight" HorizontalAlignment="Left" VerticalAlignment="Top" Visibility="Hidden" Grid.Column="2" Grid.Row="9" FontFamily="Times New Roman" FontSize="72" Margin="-30" />
      <TextBlock Name="textBreathHold" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Column="0" Grid.Row="0" Grid.RowSpan="12" Grid.ColumnSpan="3" FontSize="140" FontFamily="Times New Roman" Foreground="#FFFF00DE" Panel.ZIndex="200" />
      <TextBlock Name="textCenter" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Hidden" Grid.Column="0" Grid.Row="0" Grid.RowSpan="12" Grid.ColumnSpan="3" FontSize="80" FontFamily="Times New Roman" Foreground="#000000" FontWeight="Bold" />
      <Rectangle Name="rectGrey" Fill="#FF000000" Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="3" Grid.RowSpan="12" Opacity="0" IsHitTestVisible="False" />
      <Image Name="gradBlackTransImg" Source="/gradientblacktrans.png" Grid.Row="11" Grid.ColumnSpan="1" Stretch="Fill" />
      <Image Name="gradBlackTransFlipImg" Source="/gradientblacktrans.png" Grid.Row="11" Grid.Column="2" Grid.ColumnSpan="1" Stretch="Fill" RenderTransformOrigin="0.5,0.5">
        <UIElement.RenderTransform>
          <RotateTransform Angle="180" />
        </UIElement.RenderTransform>
      </Image>
      <Rectangle Name="beatRowEllipse" Fill="#FFFF69B4" Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="11" VerticalAlignment="Center" Height="10" IsHitTestVisible="False" />
      <Canvas Name="beatCanvas" Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="11" VerticalAlignment="Center" Height="32" />
      <Grid Name="beatBarBeatRect" Column="1" Row="11" IsHitTestVisible="False" ZIndex="100" Height="100">
        <Image Name="heart" Source="/heartbg.png" Margin="10" HorizontalAlignment="Center" Height="60" VerticalAlignment="Center" />
        <Image Name="heartWhite" Source="/heartbgwhite.png" Margin="10" Opacity="0" HorizontalAlignment="Center" Height="60" VerticalAlignment="Center" />
        <TextBlock Name="totalCurrency" Text="100" FontSize="32" VerticalAlignment="Center" Visibility="Visible" Opacity="0" TextAlignment="Center" Foreground="#FFFFFFFF" Margin="10,10,10,15" HorizontalAlignment="Center" FontFamily="Times New Roman" />
      </Grid>
      <StackPanel Name="textPanel" HorizontalAlignment="Center" VerticalAlignment="Bottom" Grid.ColumnSpan="3" Grid.RowSpan="10" />
      <ScrollViewer Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="3" HorizontalScrollBarVisibility="Auto" Style="{DynamicResource FavsScrollViewer}" VerticalScrollBarVisibility="Hidden" Background="#00FFFFFF" BorderBrush="#00000000">
        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
          <StackPanel Name="buttonStackPanel" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" ZIndex="1000" />
          <TextBox Name="userText" MinWidth="200" FontFamily="Times New Roman" TextAlignment="Center" Visibility="Collapsed" BorderThickness="2" Grid.Row="10" Grid.Column="1" Background="#99000000" HorizontalAlignment="Center" VerticalAlignment="Bottom" SelectionBrush="#FFFF1493" Foreground="#FFFFFFFF" FontSize="32" BorderBrush="#FFFF1493" KeyDown="userText_KeyDown" />
        </StackPanel>
      </ScrollViewer>
    </Grid>
    <Canvas Name="imageCanvas" Grid.ColumnSpan="3" Grid.RowSpan="12" />
  </Grid>
</Page>
