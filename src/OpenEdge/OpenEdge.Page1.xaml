<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="OpenEdge.Page1"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:OpenEdge"
      Title="Page1">
  <Page.Resources>
    <SolidColorBrush x:Key="PanelBrush" Color="#E0141018" />
    <SolidColorBrush x:Key="SoftPanelBrush" Color="#AA1B1724" />
    <SolidColorBrush x:Key="AccentBrush" Color="#FF9F5CFF" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#FFC8B6F0" />
    <SolidColorBrush x:Key="MainTextBrush" Color="#FFEDEDED" />

    <Style x:Key="MainMenuSectionTitle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource MainTextBrush}" />
      <Setter Property="FontSize" Value="22" />
      <Setter Property="FontFamily" Value="Segoe UI" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style x:Key="MainMenuOptionText" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource MainTextBrush}" />
      <Setter Property="FontSize" Value="16" />
      <Setter Property="FontFamily" Value="Segoe UI" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="HeroButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="MinWidth" Value="220" />
      <Setter Property="MinHeight" Value="68" />
      <Setter Property="Margin" Value="8" />
      <Setter Property="Padding" Value="18,12" />
      <Setter Property="FontSize" Value="24" />
      <Setter Property="FontFamily" Value="Segoe UI" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
  </Page.Resources>

  <Page.Background>
    <ImageBrush ImageSource="/background.png" Stretch="UniformToFill" />
  </Page.Background>

  <Grid>
    <Grid.Background>
      <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#D00B0810" Offset="0" />
        <GradientStop Color="#A0160F20" Offset="0.55" />
        <GradientStop Color="#D0060508" Offset="1" />
      </LinearGradientBrush>
    </Grid.Background>

    <Grid Margin="18">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="390" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Border Grid.Row="0"
              Grid.ColumnSpan="2"
              Background="#C0141018"
              BorderBrush="#669F5CFF"
              BorderThickness="1"
              CornerRadius="14"
              Padding="16"
              Margin="0,0,0,14">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="OpenEdge"
                       Foreground="{StaticResource MainTextBrush}"
                       FontSize="42"
                       FontFamily="Segoe UI"
                       FontWeight="SemiBold" />
            <TextBlock Text="0.6.5"
                       Foreground="{StaticResource MutedTextBrush}"
                       FontSize="14"
                       FontFamily="Segoe UI"
                       VerticalAlignment="Bottom"
                       Margin="14,0,0,8" />
          </StackPanel>
          <Button Grid.Column="2"
                  Content="X"
                  Width="48"
                  Height="44"
                  FontSize="22"
                  Click="Button_Click_CloseOpenEdge" />
        </Grid>
      </Border>

      <Border Grid.Row="1"
              Grid.Column="0"
              Background="{StaticResource PanelBrush}"
              BorderBrush="#669F5CFF"
              BorderThickness="1"
              CornerRadius="14"
              Padding="14">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel>
            <TextBlock Text="Quick Setup" Style="{StaticResource MainMenuSectionTitle}" />
            <Border Background="{StaticResource SoftPanelBrush}" CornerRadius="10" Padding="12" Margin="0,0,0,12">
              <StackPanel>
                <Button Content="Mods"
                        ToolTip="Manage installed mods"
                        FontSize="18"
                        Padding="12,8"
                        Margin="0,0,0,8"
                        Click="Button_Click_ModFolder" />
                <Button Content="Media Sources"
                        ToolTip="Configure image and video source folders"
                        FontSize="18"
                        Padding="12,8"
                        Margin="0,0,0,8"
                        Click="MediaSources_Click" />
                <TextBlock Name="errorLable"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Visibility="Visible"
                           Foreground="#FFFF6B6B"
                           Text=""
                           HorizontalAlignment="Center"
                           FontSize="13"
                           FontFamily="Segoe UI"
                           Opacity="0.9" />
              </StackPanel>
            </Border>

            <StackPanel Name="pronouns" Margin="0,0,0,12">
              <TextBlock Text="Pronouns" Style="{StaticResource MainMenuSectionTitle}" />
              <Border Background="{StaticResource SoftPanelBrush}" CornerRadius="10" Padding="12">
                <StackPanel>
                  <RadioButton Name="radioHeHim" Content="He/Him" IsChecked="True" Click="radio_Click" Margin="0,2,0,8" />
                  <RadioButton Name="radioSheHer" Content="She/Her" Click="radio_Click" Margin="0,2,0,8" />
                  <RadioButton Name="radioTheyThem" Content="They/Them" Click="radio_Click" Margin="0,2,0,0" />
                </StackPanel>
              </Border>
            </StackPanel>

            <StackPanel Name="sexSelect">
              <TextBlock Text="Options" Style="{StaticResource MainMenuSectionTitle}" />
              <Border Background="{StaticResource SoftPanelBrush}" CornerRadius="10" Padding="12">
                <StackPanel>
                  <Grid Margin="0,0,0,8">
                    <TextBlock Text="Mute Videos" Style="{StaticResource MainMenuOptionText}" />
                    <CheckBox Name="optionsCheckMute" Tag="0" HorizontalAlignment="Right" Click="CheckBox_Click" />
                  </Grid>
                  <Grid Margin="0,0,0,8">
                    <TextBlock Text="Hide Beatbar" Style="{StaticResource MainMenuOptionText}" />
                    <CheckBox Name="optionsHideBeatbar" Tag="1" HorizontalAlignment="Right" Click="CheckBox_Click" />
                  </Grid>
                  <Grid Margin="0,0,0,12">
                    <TextBlock Text="Fullscreen" Style="{StaticResource MainMenuOptionText}" />
                    <CheckBox Name="optionsFullScreen" Tag="2" IsChecked="True" HorizontalAlignment="Right" Click="CheckBox_Click" />
                  </Grid>

                  <Grid ToolTip="Change how fast dialogue progresses" Margin="0,8,0,8">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="140" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Text Speed" Style="{StaticResource MainMenuOptionText}" />
                    <Slider Name="textSpeedSlider" Grid.Column="1" Maximum="5" SmallChange="1" IsSnapToTickEnabled="True" TickPlacement="BottomRight" Value="3" Minimum="1" ValueChanged="textSpeedSlider_ValueChanged" />
                  </Grid>
                  <Grid ToolTip="Change how fast media changes" Margin="0,0,0,12" Visibility="Visible">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="140" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Media Speed" Style="{StaticResource MainMenuOptionText}" />
                    <Slider Name="mediaSpeedSlider" Grid.Column="1" Maximum="5" SmallChange="1" IsSnapToTickEnabled="True" TickPlacement="BottomRight" Value="3" Minimum="1" ValueChanged="mediaSpeedSlider_ValueChanged" />
                  </Grid>

                  <Button Content="Set Background"
                          FontSize="16"
                          Padding="12,8"
                          Margin="0,6,0,14"
                          ToolTip="Set a custom background image from the app folder"
                          HorizontalAlignment="Stretch"
                          Click="Button_Click_1" />

                  <Grid Margin="0,4,0,8">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="140" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Volume" Style="{StaticResource MainMenuOptionText}" />
                    <Slider Name="masterVolume" Grid.Column="1" Maximum="2" SmallChange="0.25" LargeChange="0.25" IsSnapToTickEnabled="True" TickPlacement="BottomRight" Value="1" Minimum="0" TickFrequency="0.25" ValueChanged="masterVolume_ValueChanged" />
                  </Grid>
                  <Grid Margin="0,0,0,6" ToolTip="Base volume of all videos">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="140" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Video" Foreground="{StaticResource MutedTextBrush}" FontSize="14" FontFamily="Segoe UI" Margin="18,0,0,0" />
                    <Slider Name="videoVolume" Grid.Column="1" Maximum="2" SmallChange="0.25" LargeChange="0.25" IsSnapToTickEnabled="True" TickPlacement="BottomRight" Value="1" Minimum="0" TickFrequency="0.25" ValueChanged="videoVolume_ValueChanged" />
                  </Grid>
                  <Grid Margin="0,0,0,6" ToolTip="Button clicks and strokebeat">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="140" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="UI" Foreground="{StaticResource MutedTextBrush}" FontSize="14" FontFamily="Segoe UI" Margin="18,0,0,0" />
                    <Slider Name="uiVolume" Grid.Column="1" Maximum="2" SmallChange="0.25" LargeChange="0.25" IsSnapToTickEnabled="True" TickPlacement="BottomRight" Value="1" Minimum="0" TickFrequency="0.25" ValueChanged="uiVolume_ValueChanged" />
                  </Grid>
                  <Grid Margin="0,0,0,6" ToolTip="ASMR and hypnosis droning">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="140" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="ASMR" Foreground="{StaticResource MutedTextBrush}" FontSize="14" FontFamily="Segoe UI" Margin="18,0,0,0" />
                    <Slider Name="asmrVolume" Grid.Column="1" Maximum="2" SmallChange="0.25" LargeChange="0.25" IsSnapToTickEnabled="True" TickPlacement="BottomRight" Value="1" Minimum="0" TickFrequency="0.25" ValueChanged="asmrVolume_ValueChanged" />
                  </Grid>
                  <Grid ToolTip="Text to Speech">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="140" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="TTS" Foreground="{StaticResource MutedTextBrush}" FontSize="14" FontFamily="Segoe UI" Margin="18,0,0,0" />
                    <Slider Name="ttsVolume" Grid.Column="1" Maximum="2" SmallChange="0.25" LargeChange="0.25" IsSnapToTickEnabled="True" TickPlacement="BottomRight" Value="1" Minimum="0" TickFrequency="0.25" ValueChanged="ttsVolume_ValueChanged" />
                  </Grid>
                </StackPanel>
              </Border>
            </StackPanel>
          </StackPanel>
        </ScrollViewer>
      </Border>

      <Grid Grid.Row="1" Grid.Column="1" Margin="18,0,0,0">
        <Border Background="#66141018"
                BorderBrush="#339F5CFF"
                BorderThickness="1"
                CornerRadius="16" />
        <Image Source="/domme.png"
               Margin="20,20,20,110"
               IsHitTestVisible="False"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               Stretch="Uniform" />
        <TextBlock Text="Ready when you are."
                   Foreground="{StaticResource MutedTextBrush}"
                   FontSize="18"
                   FontFamily="Segoe UI"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   Margin="0,0,0,92" />
      </Grid>

      <Border Grid.Row="2"
              Grid.ColumnSpan="2"
              Background="#D0141018"
              BorderBrush="#669F5CFF"
              BorderThickness="1"
              CornerRadius="14"
              Padding="12"
              Margin="0,14,0,0">
        <WrapPanel HorizontalAlignment="Center">
          <Grid Name="startSessionGrid" IsEnabled="True">
            <Button Name="beginButton" Content="Begin Session" Style="{StaticResource HeroButton}" Click="Button_Click" />
            <TextBlock Name="favorDebtText" Visibility="Hidden" HorizontalAlignment="Center" VerticalAlignment="Center" Text="Favor Debt" FontSize="34" FontFamily="Segoe UI" Foreground="#FFFF4B4B" RenderTransformOrigin="0.5,0.5" FontWeight="Bold" IsHitTestVisible="False">
              <UIElement.RenderTransform>
                <TransformGroup>
                  <ScaleTransform />
                  <SkewTransform />
                  <RotateTransform Angle="12.0" />
                  <TranslateTransform />
                </TransformGroup>
              </UIElement.RenderTransform>
            </TextBlock>
          </Grid>
          <Button Name="tagBtn" Content="Tag Media" Style="{StaticResource HeroButton}" Click="TagImages" />
          <Button Name="settingsBtn" Content="Settings" Style="{StaticResource HeroButton}" Click="Settings_Click" />
          <Button Name="homeworkBtn" Content="Tasks" Style="{StaticResource HeroButton}" Visibility="Collapsed" Click="homework_Click" />
        </WrapPanel>
      </Border>
    </Grid>

    <local:ModsPopup x:Name="modsPopup" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center" />
  </Grid>
</Page>
