<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="OpenEdge.CompatibilityToolsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Background="#FF101014">
  <Grid Margin="14">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <TextBlock Text="Migration &amp; Compatibility Tools"
               FontFamily="Segoe UI"
               FontSize="34"
               Foreground="#FFEDEDED"
               Margin="0,0,0,10" />
    <TextBlock Grid.Row="1"
               Name="SummaryText"
               TextWrapping="Wrap"
               FontSize="15"
               Foreground="#FFD6D6D6"
               Margin="0,0,0,20" />
    <Border Grid.Row="2"
            Background="#E0141418"
            BorderBrush="#668A6AB0"
            BorderThickness="1"
            CornerRadius="10"
            Padding="20">
      <StackPanel>
        <TextBlock Text="Import saved data from EverEdge, or back up and restore this OpenEdge install. Diagnostics are for troubleshooting."
                   TextWrapping="Wrap"
                   Foreground="#FFEDEDED"
                   FontSize="16"
                   Margin="0,0,0,20" />
        <Button Content="Import Data from EverEdge"
                Height="38"
                Margin="0,0,0,12"
                Click="ImportEverEdge_Click" />
        <Button Content="Export User Data"
                Height="38"
                Margin="0,0,0,12"
                Click="Export_Click" />
        <Button Content="Import User Data"
                Height="38"
                Margin="0,0,0,12"
                Click="Import_Click" />
        <Button Content="Export Diagnostics"
                Height="38"
                Margin="0,0,0,12"
                Click="ExportDiagnostics_Click" />
        <TextBlock Name="StatusText"
                   Margin="0,16,0,0"
                   TextWrapping="Wrap"
                   Foreground="#FFD6D6D6"
                   FontSize="16" />
      </StackPanel>
    </Border>
    <StackPanel Grid.Row="3"
                Orientation="Horizontal"
                HorizontalAlignment="Center"
                Margin="0,20,0,0">
      <Button Content="Refresh"
              Width="150"
              Height="38"
              Margin="10"
              Click="Refresh_Click" />
      <Button Content="Back"
              Width="150"
              Height="38"
              Margin="10"
              Click="Back_Click" />
    </StackPanel>
  </Grid>
</Page>
