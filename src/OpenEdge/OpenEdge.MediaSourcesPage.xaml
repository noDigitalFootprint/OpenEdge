<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="OpenEdge.MediaSourcesPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" mc:Ignorable="d" Background="#FF101014">
  <Grid Margin="14">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <TextBlock Text="Media Sources" FontFamily="Segoe UI" FontSize="34" Foreground="#FFEDEDED" Margin="0,0,0,10" />
    <TextBlock Grid.Row="1" Name="SummaryText" TextWrapping="Wrap" FontSize="15" Foreground="#FFD6D6D6" Margin="0,0,0,16" />
    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
      <StackPanel Name="SourcesPanel" />
    </ScrollViewer>
    <StackPanel Grid.Row="3" Margin="0,20,0,0">
      <Border Name="ImportStatusPanel"
              Visibility="Collapsed"
              Background="#E0141418"
              BorderBrush="#668A6AB0"
              BorderThickness="1"
              CornerRadius="8"
              Padding="10"
              Margin="0,0,0,10">
        <StackPanel>
          <TextBlock Name="ImportStatusText"
                     Text="Importing legacy tags..."
                     TextWrapping="Wrap"
                     Foreground="#FFEDEDED"
                     FontSize="13"
                     Margin="0,0,0,8" />
          <ProgressBar Name="ImportProgressBar"
                       Height="14"
                       IsIndeterminate="True" />
        </StackPanel>
      </Border>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
        <Button Content="Add Folder" Width="150" Height="38" Margin="8" Click="AddFolder_Click" />
        <Button Name="ImportLegacyTagsButton" Content="Import Legacy Tags" Width="170" Height="38" Margin="8" Click="ImportLegacyTags_Click" />
        <Button Content="Save" Width="150" Height="38" Margin="8" Click="Save_Click" />
        <Button Content="Back" Width="150" Height="38" Margin="8" Click="Back_Click" />
      </StackPanel>
    </StackPanel>
  </Grid>
</Page>
