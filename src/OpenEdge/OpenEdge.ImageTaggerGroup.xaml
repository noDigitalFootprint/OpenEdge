<?xml version="1.0" encoding="utf-8"?>
<Grid x:Class="OpenEdge.ImageTaggerGroup"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      Width="720"
      Height="340"
      HorizontalAlignment="Center"
      VerticalAlignment="Center"
      mc:Ignorable="d">
  <Border Background="#EE1B1B1B"
          BorderBrush="#55FFFFFF"
          BorderThickness="1"
          CornerRadius="12"
          Padding="20">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <TextBlock Grid.Row="0"
                 Grid.Column="0"
                 Margin="0,0,16,12"
                 Text="Save the current tags into a group, then press 1-5 later to apply that group to another media item."
                 Foreground="White"
                 FontFamily="Times New Roman"
                 FontSize="28"
                 TextWrapping="Wrap" />

      <Button x:Name="closePopUp"
              Grid.Row="0"
              Grid.Column="1"
              Content="X"
              FontSize="36"
              MinWidth="56"
              Height="56"
              Background="#007E2882"
              BorderBrush="#FFFFFFFF"
              Foreground="#FFFFFFFF"
              HorizontalAlignment="Right"
              VerticalAlignment="Top"
              Click="closePopUp_Click" />

      <StackPanel Grid.Row="1"
                  Grid.ColumnSpan="2"
                  Orientation="Horizontal"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">
        <Button Content="1" Tag="0" Height="60" MinWidth="70" Click="Button_Click" MouseEnter="Button_MouseEnter" MouseLeave="Button_MouseLeave" />
        <Button Content="2" Tag="1" Height="60" MinWidth="70" Click="Button_Click" MouseEnter="Button_MouseEnter" MouseLeave="Button_MouseLeave" />
        <Button Content="3" Tag="2" Height="60" MinWidth="70" Click="Button_Click" MouseEnter="Button_MouseEnter" MouseLeave="Button_MouseLeave" />
        <Button Content="4" Tag="3" Height="60" MinWidth="70" Click="Button_Click" MouseEnter="Button_MouseEnter" MouseLeave="Button_MouseLeave" />
        <Button Content="5" Tag="4" Height="60" MinWidth="70" Click="Button_Click" MouseEnter="Button_MouseEnter" MouseLeave="Button_MouseLeave" />
      </StackPanel>

      <TextBlock x:Name="textWithShortcut"
                 Grid.Row="2"
                 Grid.ColumnSpan="2"
                 Margin="0,12,0,0"
                 Text=""
                 Visibility="Collapsed"
                 Foreground="#FFFFFFFF"
                 FontFamily="Times New Roman"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Bottom"
                 TextAlignment="Center"
                 TextWrapping="Wrap"
                 FontSize="18" />
    </Grid>
  </Border>
</Grid>
