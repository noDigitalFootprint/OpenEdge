<?xml version="1.0" encoding="utf-8"?>
<Application x:Class="OpenEdge.App" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:local="clr-namespace:OpenEdge">
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="scrollbar.xaml" />
      </ResourceDictionary.MergedDictionaries>
      <SolidColorBrush x:Key="OpenEdgeBackgroundBrush" Color="#FF101014" />
      <SolidColorBrush x:Key="OpenEdgePanelBrush" Color="#E0141418" />
      <SolidColorBrush x:Key="OpenEdgeControlBrush" Color="#66303030" />
      <SolidColorBrush x:Key="OpenEdgeControlHoverBrush" Color="#88463058" />
      <SolidColorBrush x:Key="OpenEdgeControlPressedBrush" Color="#AA563A6C" />
      <SolidColorBrush x:Key="OpenEdgeAccentBrush" Color="#FF8A6AB0" />
      <SolidColorBrush x:Key="OpenEdgeAccentDimBrush" Color="#668A6AB0" />
      <SolidColorBrush x:Key="OpenEdgeTextBrush" Color="#FFEDEDED" />
      <SolidColorBrush x:Key="OpenEdgeMutedTextBrush" Color="#FFD6D6D6" />

      <Style x:Key="{x:Type CheckBox}" TargetType="{x:Type CheckBox}">
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Foreground" Value="{StaticResource OpenEdgeTextBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Margin" Value="4" />
      </Style>
      <Style x:Key="{x:Type RadioButton}" TargetType="{x:Type RadioButton}">
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Foreground" Value="{StaticResource OpenEdgeTextBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="13" />
      </Style>
      <Style x:Key="{x:Type Button}" TargetType="{x:Type Button}">
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Background" Value="{StaticResource OpenEdgeControlBrush}" />
        <Setter Property="Foreground" Value="{StaticResource OpenEdgeTextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource OpenEdgeAccentDimBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="MinHeight" Value="30" />
        <Setter Property="MinWidth" Value="82" />
        <Setter Property="Padding" Value="9,4" />
        <Setter Property="Margin" Value="4" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="{x:Type Button}">
              <Border x:Name="ButtonBorder"
                      Background="{TemplateBinding Background}"
                      BorderBrush="{TemplateBinding BorderBrush}"
                      BorderThickness="{TemplateBinding BorderThickness}"
                      CornerRadius="5">
                <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Margin="{TemplateBinding Padding}"
                                  RecognizesAccessKey="True" />
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource OpenEdgeControlHoverBrush}" />
                  <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{StaticResource OpenEdgeAccentBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                  <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource OpenEdgeControlPressedBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                  <Setter Property="Foreground" Value="#FF777777" />
                  <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>
      <Style x:Key="{x:Type local:Btn}" TargetType="{x:Type local:Btn}" BasedOn="{StaticResource {x:Type Button}}" />
      <Style x:Key="{x:Type TextBox}" TargetType="{x:Type TextBox}">
        <Setter Property="Background" Value="#FF1C1C22" />
        <Setter Property="Foreground" Value="{StaticResource OpenEdgeTextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource OpenEdgeAccentDimBrush}" />
        <Setter Property="CaretBrush" Value="{StaticResource OpenEdgeTextBrush}" />
        <Setter Property="SelectionBrush" Value="#AA7E2882" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="8,4" />
      </Style>
      <Style x:Key="{x:Type ComboBox}" TargetType="{x:Type ComboBox}">
        <Setter Property="Background" Value="#FF1C1C22" />
        <Setter Property="Foreground" Value="{StaticResource OpenEdgeTextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource OpenEdgeAccentDimBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="6,4" />
      </Style>
      <Style x:Key="{x:Type ListBox}" TargetType="{x:Type ListBox}">
        <Setter Property="Background" Value="#22000000" />
        <Setter Property="Foreground" Value="{StaticResource OpenEdgeTextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource OpenEdgeAccentDimBrush}" />
      </Style>
    </ResourceDictionary>
  </Application.Resources>
</Application>
