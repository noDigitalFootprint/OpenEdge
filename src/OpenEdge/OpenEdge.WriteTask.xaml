<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="OpenEdge.WriteTask" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:local="clr-namespace:OpenEdge" Title="WriteTask">
  <Page.Background>
    <ImageBrush ImageSource="/background.png" />
  </Page.Background>
  <Grid Focusable="False">
    <MediaElement Name="blurredBg" IsMuted="True" Stretch="Uniform" Opacity="0.5" Focusable="False" Visibility="Visible" Grid.ColumnSpan="6" Volume="0.1" LoadedBehavior="Manual" MediaEnded="mediaElement_OnMediaEnded">
      <UIElement.Effect>
        <BlurEffect Radius="160" />
      </UIElement.Effect>
    </MediaElement>
    <MediaElement Name="focussedBg" IsMuted="True" Stretch="Uniform" Focusable="False" LoadedBehavior="Manual">
      <UIElement.OpacityMask>
        <VisualBrush Stretch="Uniform">
          <VisualBrush.Visual>
            <UniformGrid Name="textStack" Focusable="False" Rows="20" Columns="1">
              <TextBlock Name="firstSentence" Text="Domina knows what's best for me" FontWeight="Bold" FontFamily="Times New Roman" Margin="2,-2,2,-2" />
            </UniformGrid>
          </VisualBrush.Visual>
        </VisualBrush>
      </UIElement.OpacityMask>
    </MediaElement>
    <TextBox Name="textBox" Text="" Foreground="#02FF1493" Background="#02FFFFFF" SelectionTextBrush="#02FFFFFF" CaretBrush="#02000000" KeyUp="textBox_KeyUp" LostKeyboardFocus="textBox_LostKeyboardFocus" />
    <Button Name="backBtnTask" Content="Show Task" Grid.Row="12" Grid.Column="0" Grid.ColumnSpan="2" Margin="40,20,40,20" Visibility="Visible" VerticalAlignment="Bottom" HorizontalAlignment="Left" Click="showTaskClick" />
  </Grid>
</Page>