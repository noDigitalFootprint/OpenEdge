<UserControl x:Class="OpenEdge.MediaBrowser"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="420">
<UserControl.Resources>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Foreground" Value="#FFEDEDED" />
            <Setter Property="Background" Value="#6630243A" />
            <Setter Property="BorderBrush" Value="#668A6AB0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#884A315E" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#AAE39BE8" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#AA7E2882" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#FFE39BE8" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#FF777777" />
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#33222228" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#3344444A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ToggleButton">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Foreground" Value="#FFEDEDED" />
            <Setter Property="Background" Value="#6630243A" />
            <Setter Property="BorderBrush" Value="#668A6AB0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ToggleBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleBorder" Property="Background" Value="#884A315E" />
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="#AAE39BE8" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ToggleBorder" Property="Background" Value="#AA7E2882" />
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="#FFE39BE8" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ToggleBorder" Property="Background" Value="#CC5D1F63" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#FF777777" />
                                <Setter TargetName="ToggleBorder" Property="Background" Value="#33222228" />
                                <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="#3344444A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DarkComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#FF222222"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#FF7E2882"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#FF888888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DarkComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#FF1C1C1C"/>
            <Setter Property="BorderBrush" Value="#66FFFFFF"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Style>
                                    <Style TargetType="ToggleButton">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <Border x:Name="Border"
                                                            Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="3">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="20"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Path x:Name="Arrow"
                                                                  Grid.Column="1"
                                                                  Data="M 0 0 L 4 4 L 8 0 Z"
                                                                  Fill="White"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Border" Property="Background" Value="#FF2C2C2C"/>
                                                        </Trigger>
                                                        <Trigger Property="IsChecked" Value="True">
                                                            <Setter TargetName="Border" Property="Background" Value="#FF3C3C3C"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ToggleButton.Style>
                            </ToggleButton>
                            <ContentPresenter
                                  IsHitTestVisible="False"
                                  Content="{TemplateBinding SelectionBoxItem}"
                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                  Margin="6,3,23,3"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Left">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="White"/>
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   PopupAnimation="Slide">
                                <Border x:Name="DropDownBorder"
                                        Background="#FF222222"
                                        BorderBrush="#66FFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="3"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer>
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="DropDownBorder" Property="MinHeight" Value="95"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#FF888888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DarkTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#FF1C1C1C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CaretBrush" Value="White"/>
            <Setter Property="BorderBrush" Value="#66FFFFFF"/>
            <Setter Property="SelectionBrush" Value="#AA7E2882"/>
        </Style>
        <Style x:Key="DarkDatePickerStyle" TargetType="DatePicker">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#FF1C1C1C"/>
            <Setter Property="BorderBrush" Value="#66FFFFFF"/>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,8"
                Padding="10"
                CornerRadius="8"
                Background="#33000000"
                BorderBrush="#33FFFFFF"
                BorderThickness="1">
            <StackPanel>
                <TextBox x:Name="SearchTextBox"
                         Style="{StaticResource DarkTextBoxStyle}"
                         Height="34"
                         Margin="0,0,0,8"
                         Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Background="#66000000"
                         Foreground="White"
                         BorderBrush="#66FFFFFF"/>
                <WrapPanel>
                    <TextBlock Text="Type"
                               Foreground="#CCFFFFFF"
                               VerticalAlignment="Center"
                               Margin="0,0,6,8"/>
                    <ComboBox x:Name="MediaTypeCombo"
                              Style="{StaticResource DarkComboBoxStyle}"
                              Width="110"
                              Height="32"
                              Margin="0,0,8,8"
                              SelectionChanged="MediaTypeCombo_SelectionChanged"
                              ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}">
                        <ComboBoxItem Content="All" Tag="All" Background="#FF222222" Foreground="White"/>
                        <ComboBoxItem Content="Images" Tag="Image" Background="#FF222222" Foreground="White"/>
                        <ComboBoxItem Content="Videos" Tag="Video" Background="#FF222222" Foreground="White"/>
                        <ComboBoxItem Content="GIFs" Tag="Gif" Background="#FF222222" Foreground="White"/>
                    </ComboBox>
                    <TextBlock Text="Source"
                               Foreground="#CCFFFFFF"
                               VerticalAlignment="Center"
                               Margin="0,0,6,8"/>
                    <ComboBox x:Name="SourceCombo"
                              Style="{StaticResource DarkComboBoxStyle}"
                              Width="140"
                              Height="32"
                              Margin="0,0,8,8"
                              SelectionChanged="SourceCombo_SelectionChanged"
                              ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}">
                        <ComboBoxItem Content="All Sources" Tag="" Background="#FF222222" Foreground="White"/>
                    </ComboBox>
                    <TextBlock Text="Sort"
                               Foreground="#CCFFFFFF"
                               VerticalAlignment="Center"
                               Margin="0,0,6,8"/>
                    <ComboBox x:Name="SortFieldCombo"
                              Style="{StaticResource DarkComboBoxStyle}"
                              Width="105"
                              Height="32"
                              Margin="0,0,8,8"
                              SelectionChanged="SortFieldCombo_SelectionChanged"
                              ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}">
                        <ComboBoxItem Content="Name" Tag="Name" Background="#FF222222" Foreground="White"/>
                        <ComboBoxItem Content="Date" Tag="Date" Background="#FF222222" Foreground="White"/>
                        <ComboBoxItem Content="Size" Tag="Size" Background="#FF222222" Foreground="White"/>
                    </ComboBox>
                    <ComboBox x:Name="SortDirectionCombo"
                               Style="{StaticResource DarkComboBoxStyle}"
                               Width="110"
                              Height="32"
                              Margin="0,0,8,8"
                              SelectionChanged="SortDirectionCombo_SelectionChanged"
                              ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}">
                        <ComboBoxItem Content="Ascending" Tag="Ascending" Background="#FF222222" Foreground="White"/>
                        <ComboBoxItem Content="Descending" Tag="Descending" Background="#FF222222" Foreground="White"/>
                    </ComboBox>
                    <ToggleButton x:Name="ThumbnailToggle"
                                   Content="Thumbs Off"
                                   Width="96"
                                   Height="32"
                                   Margin="0,0,8,8"
                                   Click="ThumbnailToggle_Click"
                                   Background="#66000000"
                                   Foreground="White"
                                   BorderBrush="#66FFFFFF"
                                   IsChecked="False"/>
                     <Button Content="↻"
                             Width="38"
                             Height="32"
                             Margin="0,0,0,8"
                             Click="RefreshButton_Click"
                            Background="#66000000"
                            Foreground="White"
                            BorderBrush="#66FFFFFF"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <Border x:Name="TilePagingPanel"
                  Grid.Row="0"
                  Visibility="Collapsed"
                  Margin="0,0,0,8"
                  Padding="8"
                  Background="#33000000"
                  BorderBrush="#33FFFFFF"
                  BorderThickness="1"
                  CornerRadius="6">
            <DockPanel LastChildFill="True">
              <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="Tile"
                           VerticalAlignment="Center"
                           Foreground="#CCFFFFFF"
                           Margin="0,0,6,0" />
                <ComboBox x:Name="TileSizeCombo"
                          Style="{StaticResource DarkComboBoxStyle}"
                          Width="86"
                          Height="30"
                          Margin="0,0,8,0"
                          SelectionChanged="TileSizeCombo_SelectionChanged"
                          ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}">
                  <ComboBoxItem Content="Small" Tag="110" Background="#FF222222" Foreground="White"/>
                  <ComboBoxItem Content="Medium" Tag="150" Background="#FF222222" Foreground="White"/>
                  <ComboBoxItem Content="Large" Tag="220" Background="#FF222222" Foreground="White"/>
                </ComboBox>
                <Button Content="Select Visible"
                        Width="116"
                        Height="30"
                        Margin="0,0,8,0"
                        Click="SelectVisibleButton_Click" />
                <Button Content="Clear Selection"
                        Width="116"
                        Height="30"
                        Margin="0,0,8,0"
                        Click="ClearSelectionButton_Click" />
                <Button x:Name="ShowMoreTilesButton"
                        Content="Show More"
                        Width="110"
                        Height="30"
                        HorizontalAlignment="Right"
                        Click="ShowMoreTilesButton_Click" />
              </StackPanel>
              <TextBlock x:Name="TilePagingStatusText"
                         VerticalAlignment="Center"
                         Foreground="#FFD6D6D6"
                         FontSize="13" />
            </DockPanel>
          </Border>
        <ListBox x:Name="MediaItemsControl"
                 Grid.Row="1"
                 Background="#22000000"
                 BorderBrush="#33FFFFFF"
                 Foreground="White"
                 ItemsSource="{Binding MediaItems}"
                 SelectionMode="Extended"
                 SelectionChanged="MediaItemsControl_SelectionChanged"
                 ScrollViewer.CanContentScroll="True"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling">
            <ListBox.Resources>
                <DataTemplate x:Key="ListMediaItemTemplate">
                    <Border Padding="8"
                            CornerRadius="8"
                            Background="#33000000"
                            BorderBrush="#44FFFFFF"
                            BorderThickness="1">
                        <DockPanel>
                            <Border Height="64"
                                    Width="64"
                                    DockPanel.Dock="Left"
                                    Margin="0,0,10,0"
                                    Background="#11000000"
                                    CornerRadius="6"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top">
                                <Grid>
                                    <Image Source="{Binding Thumbnail}"
                                           Width="64"
                                           Height="64"
                                           Stretch="UniformToFill" />
                                    <TextBlock Text="{Binding KindString}"
                                               Foreground="#CCFFFFFF"
                                               FontSize="12"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Thumbnail}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding KindString}" Value="Video">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="{Binding FileName}"
                                           Foreground="White"
                                           FontWeight="Bold"
                                           TextWrapping="Wrap"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding RelativePath}"
                                           Margin="0,4,0,0"
                                           Foreground="#CCFFFFFF"
                                           FontSize="11"
                                           TextWrapping="Wrap"
                                           TextTrimming="CharacterEllipsis"
                                           MaxHeight="32" />
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <TextBlock Text="{Binding KindString}" Foreground="#CCFFFFFF" FontSize="11" />
                                    <TextBlock Text=" • " Foreground="#88FFFFFF" FontSize="11" />
                                    <TextBlock Text="{Binding SizeString}" Foreground="#CCFFFFFF" FontSize="11" />
                                </StackPanel>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </DataTemplate>
                <DataTemplate x:Key="TileMediaItemTemplate">
                    <Border Padding="8"
                            CornerRadius="8"
                            Background="#33000000"
                            BorderBrush="#44FFFFFF"
                            BorderThickness="1">
                        <StackPanel>
                            <Border Height="{Binding TilePreviewHeight, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    Background="#11000000"
                                    CornerRadius="6">
                                <Grid>
                                    <Image Source="{Binding Thumbnail}"
                                           Stretch="UniformToFill" />
                                    <TextBlock Text="{Binding KindString}"
                                               Foreground="#CCFFFFFF"
                                               FontSize="16"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Thumbnail}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding KindString}" Value="Video">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>
                            <TextBlock Text="{Binding FileName}"
                                       Margin="0,8,0,0"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       TextTrimming="CharacterEllipsis"
                                       MaxHeight="42" />
                            <TextBlock Text="{Binding SizeString}"
                                       Margin="0,4,0,0"
                                       Foreground="#CCFFFFFF"
                                       FontSize="11"
                                       TextAlignment="Center" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.Resources>
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,0,0,6" />
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <StaticResource ResourceKey="ListMediaItemTemplate" />
            </ListBox.ItemTemplate>
        </ListBox>
        </Grid>
    </Grid>
</UserControl>
